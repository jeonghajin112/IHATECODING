{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ihatecoding.local/contracts/projects-v1.schema.json",
  "title": "IHATECODING project catalog v1",
  "type": "object",
  "required": ["Projects", "SelectedProjectId"],
  "properties": {
    "Projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/project" }
    },
    "SelectedProjectId": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "project": {
      "type": "object",
      "required": ["Id", "Name", "FolderPath", "Terminals", "PaneWidthRatios"],
      "properties": {
        "Id": { "type": "string", "minLength": 1 },
        "Name": { "type": "string", "minLength": 1 },
        "FolderPath": { "type": "string", "minLength": 1 },
        "Terminals": {
          "type": "array",
          "description": "Pane count has no product-level per-project cap; storage payload and runtime resource guards are enforced separately.",
          "items": { "$ref": "#/$defs/terminal" }
        },
        "PaneWidthRatios": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      },
      "additionalProperties": false
    },
    "terminal": {
      "type": "object",
      "required": [
        "Id",
        "Name",
        "StartDirectory",
        "CodexThreadId",
        "GrokSessionId",
        "CreatedAtUtc",
        "CompletionPending"
      ],
      "properties": {
        "Id": { "type": "string", "minLength": 1 },
        "Name": { "type": "string", "minLength": 1 },
        "StartDirectory": { "type": "string", "minLength": 1 },
        "CodexThreadId": { "type": ["string", "null"] },
        "GrokSessionId": { "type": ["string", "null"] },
        "CreatedAtUtc": { "type": ["string", "null"], "format": "date-time" },
        "CompletionPending": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
